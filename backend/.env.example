# Heroku/production-ready backend environment template.
# Heroku sets PORT automatically; FASTAPI_PORT is used only outside Heroku.
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Comma-separated exact origins that can call your API.
ALLOWED_ORIGINS=https://auralmind.netlify.app,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Optional regex for Netlify deploy previews.
ALLOWED_ORIGIN_REGEX=https://.*auralmind\.netlify\.app

MAX_UPLOAD_MB=200
JOB_TIMEOUT_SEC=3600

# AI (Ollama)
# `OLLAMA_BASE_URL_CLOUD` and `OLLAMA_BASE_URL_LOCAL` may include or omit `/api`.
# The backend normalizes both to the official chat base and calls `POST /api/chat`.
OLLAMA_BASE_URL_CLOUD=https://ollama.com
OLLAMA_BASE_URL_LOCAL=http://localhost:11434
OLLAMA_API_KEY=
AURALMIND_AI_MODEL=glm-5:cloud
# Optional local-only model for failover when cloud model names are not installed locally.
AURALMIND_AI_MODEL_LOCAL=llama3.2
AURALMIND_AI_TIMEOUT_SEC=120
AURALMIND_AI_KEEP_ALIVE=-1
AURALMIND_AI_MAX_INPUT_CHARS=15000
